# =====================================================
# Deone's Gourmet Trotters — environment variables
# Copy to .env.local for local dev. Set the same values in
# Vercel → Project → Settings → Environment Variables.
# =====================================================

# --- Supabase (already provisioned, project: deones-gourmet-trotters) ---
NEXT_PUBLIC_SUPABASE_URL=https://bvoikfzgtukzllsvpeqw.supabase.co
# Get from Supabase dashboard → Project Settings → API → service_role (secret).
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe (grandma's account) ---
# Get from Stripe dashboard → Developers → API keys.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Get from Stripe dashboard → Developers → Webhooks → add endpoint
# pointing at https://YOUR-DOMAIN/api/webhook → reveal signing secret.
STRIPE_WEBHOOK_SECRET=

# --- Site URL ---
# Used to build success/cancel URLs and the QR code target.
# In Vercel preview/prod this auto-resolves from VERCEL_URL if blank.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Order pad PIN (staff-only access to /order) ---
# Four-digit PIN grandma punches in to unlock the order pad.
# Change in Vercel anytime — old sessions stay valid until cookie expires.
ORDER_PAD_PIN=8421
